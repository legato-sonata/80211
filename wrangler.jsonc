{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "80211",
  "compatibility_date": "2024-06-19",
  "observability": {
    "enabled": true
  },
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "80211.web.id",
      "custom_domain": true
    }
  ]
}
